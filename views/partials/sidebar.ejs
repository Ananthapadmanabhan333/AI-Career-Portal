<!-- Premium Dashboard Sidebar -->
<aside class="sidebar-wrapper glass-card">
  <div class="sidebar-profile text-center mb-4">
    <div class="avatar-glow mx-auto mb-3">
      <div class="avatar-placeholder text-uppercase">
        <%= user.username.charAt(0) %>
      </div>
    </div>
    <h5 class="profile-name mb-1 font-outfit text-white"><%= user.username %></h5>
    <span class="badge badge-glow rounded-pill text-uppercase text-gradient-accent px-3 py-1 text-xs">
      <i class="fa-solid fa-user-shield me-1"></i><%= user.role %>
    </span>
  </div>

  <hr class="border-secondary opacity-25">

  <nav class="sidebar-navigation mt-4">
    <ul class="list-unstyled">
      <li>
        <a href="#overview" class="nav-item-sidebar active" onclick="switchDashboardTab('overview')">
          <i class="fa-solid fa-chart-line me-3"></i>Overview
        </a>
      </li>
      <li>
        <a href="#jobs" class="nav-item-sidebar" onclick="switchDashboardTab('jobs')">
          <i class="fa-solid fa-briefcase me-3"></i>Explore Internships
        </a>
      </li>
      <li>
        <a href="#applications" class="nav-item-sidebar" onclick="switchDashboardTab('applications')">
          <i class="fa-solid fa-paper-plane me-3"></i>Applications
        </a>
      </li>
      
      <% if (user.role === 'Recruiter' || user.role === 'Admin') { %>
        <hr class="border-secondary opacity-25 my-3">
        <div class="sidebar-section-heading text-xs text-muted text-uppercase px-3 mb-2">Recruitment</div>
        <li>
          <a href="#post-job" class="nav-item-sidebar" onclick="switchDashboardTab('post-job')">
            <i class="fa-solid fa-circle-plus me-3"></i>Post New Internship
          </a>
        </li>
      <% } %>
    </ul>
  </nav>

  <div class="sidebar-footer mt-auto pt-4">
    <div class="card bg-dark-50 border-0 rounded-4 p-3 glass-inset">
      <div class="d-flex align-items-center">
        <i class="fa-solid fa-sparkles text-gradient me-2 fs-5"></i>
        <div class="text-xs text-light">AI Credits: <span class="fw-bold">Unlimited</span></div>
      </div>
    </div>
  </div>
</aside>
