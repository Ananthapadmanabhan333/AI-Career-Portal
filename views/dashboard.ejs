<%- include('partials/header') %>

<div class="dashboard-container py-4">
  <div class="container">
    <div class="row">
      <!-- Left sidebar layout (responsive sizing) -->
      <div class="col-lg-3 mb-4">
        <%- include('partials/sidebar') %>
      </div>

      <!-- Right main analytical panel -->
      <main class="col-lg-9">
        
        <!-- Tab: Overview Panel -->
        <div id="tab-overview" class="dashboard-tab-content active-tab animate-fade-in">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
              <h2 class="font-outfit text-white mb-1">Telemetry Dashboard</h2>
              <p class="text-muted text-sm">Real-time indicators and predictive ATS tracking matrix</p>
            </div>
            <span class="badge rounded-pill bg-success-10 border border-success border-opacity-10 text-success text-xs px-3 py-2">
              <i class="fa-solid fa-server me-1"></i>System Running
            </span>
          </div>

          <!-- Dynamic Statistics Grid -->
          <div class="row g-3 mb-4">
            <div class="col-sm-6 col-xl-3">
              <div class="glass-card p-3 d-flex align-items-center">
                <div class="stat-icon-wrapper bg-primary-10 text-primary me-3">
                  <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <div>
                  <div class="text-xs text-muted">Talent Active</div>
                  <h4 class="mb-0 font-outfit text-white" id="stat-users">--</h4>
                </div>
              </div>
            </div>

            <div class="col-sm-6 col-xl-3">
              <div class="glass-card p-3 d-flex align-items-center">
                <div class="stat-icon-wrapper bg-success-10 text-success me-3">
                  <i class="fa-solid fa-briefcase"></i>
                </div>
                <div>
                  <div class="text-xs text-muted">Internships</div>
                  <h4 class="mb-0 font-outfit text-white" id="stat-jobs">--</h4>
                </div>
              </div>
            </div>

            <div class="col-sm-6 col-xl-3">
              <div class="glass-card p-3 d-flex align-items-center">
                <div class="stat-icon-wrapper bg-info-10 text-info me-3">
                  <i class="fa-solid fa-paper-plane"></i>
                </div>
                <div>
                  <div class="text-xs text-muted">Submissions</div>
                  <h4 class="mb-0 font-outfit text-white" id="stat-apps">--</h4>
                </div>
              </div>
            </div>

            <div class="col-sm-6 col-xl-3">
              <div class="glass-card p-3 d-flex align-items-center">
                <div class="stat-icon-wrapper bg-warning-10 text-warning me-3">
                  <i class="fa-solid fa-brain-circuit"></i>
                </div>
                <div>
                  <div class="text-xs text-muted">Avg ATS Score</div>
                  <h4 class="mb-0 font-outfit text-white" id="stat-avg-score">--%</h4>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Actions & Recent Applications layout -->
          <div class="row g-4">
            <div class="col-md-7">
              <div class="glass-card p-4 h-100">
                <h5 class="font-outfit text-white mb-3"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Recent Actions</h5>
                
                <div class="recent-list-wrapper mt-3" id="recent-applications-list">
                  <!-- JS generated elements -->
                  <div class="text-center py-4 text-muted text-sm">
                    <i class="fa-solid fa-spinner fa-spin fs-4 mb-2 d-block"></i>Gathering actions...
                  </div>
                </div>
              </div>
            </div>

            <div class="col-md-5">
              <div class="glass-card p-4 h-100 text-center d-flex flex-column justify-content-center align-items-center">
                <i class="fa-solid fa-robot text-gradient fs-1 mb-3"></i>
                <h5 class="font-outfit text-white mb-2">Unlock Career Insights</h5>
                <p class="text-muted text-xs text-center px-2">
                  Apply to any internship post, submit your resume, and the Gemini parser will return structural suggestions and skills assessments in seconds.
                </p>
                <a href="#jobs" class="btn btn-premium rounded-pill btn-sm px-4 mt-2" onclick="switchDashboardTab('jobs')">
                  Apply Now<i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab: Explore Internships -->
        <div id="tab-jobs" class="dashboard-tab-content d-none animate-fade-in">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
              <h2 class="font-outfit text-white mb-1">Explore Open Positions</h2>
              <p class="text-muted text-sm">Match and apply with real-time feedback loops</p>
            </div>
            
            <!-- Live Search input trigger (Task 4 requirement) -->
            <div class="search-input-wrapper">
              <i class="fa-solid fa-magnifying-glass search-input-icon"></i>
              <input 
                type="text" 
                id="jobsSearchBox" 
                class="form-control" 
                placeholder="Search jobs, company, skills..."
                onkeyup="debounceSearch()"
              >
            </div>
          </div>

          <!-- Dynamic job list -->
          <div class="row g-3" id="jobsContainer">
            <!-- JS populated cards list -->
            <div class="col-12 text-center py-5">
              <i class="fa-solid fa-circle-notch fa-spin fs-2 text-primary"></i>
            </div>
          </div>
        </div>

        <!-- Tab: Application History -->
        <div id="tab-applications" class="dashboard-tab-content d-none animate-fade-in">
          <div class="mb-4">
            <h2 class="font-outfit text-white mb-1">Application Track Record</h2>
            <p class="text-muted text-sm">Review your application status and deep dive into AI analytics</p>
          </div>

          <div class="glass-card overflow-hidden">
            <div class="table-responsive">
              <table class="table table-hover glass-table mb-0 align-middle">
                <thead>
                  <tr>
                    <th>Internship / Company</th>
                    <th>Date Applied</th>
                    <th>Status</th>
                    <th>AI Score</th>
                    <th class="text-end">AI Report</th>
                  </tr>
                </thead>
                <tbody id="applicationRecordsBody">
                  <!-- Dynamic rows generated by JS -->
                  <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                      <i class="fa-solid fa-spinner fa-spin fs-4 mb-2 d-block"></i>Loading application logs...
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Tab: Recruiter Post Job (Visible only to Recruiter/Admin) -->
        <% if (user.role === 'Recruiter' || user.role === 'Admin') { %>
          <div id="tab-post-job" class="dashboard-tab-content d-none animate-fade-in">
            <div class="mb-4">
              <h2 class="font-outfit text-white mb-1">Post New Internship Role</h2>
              <p class="text-muted text-sm">Fill details below to pre-seed the public job board</p>
            </div>

            <div class="glass-card p-4 p-sm-5">
              <form id="recruiterPostJobForm">
                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label text-sm text-light">Job Title</label>
                    <input type="text" class="form-control" name="title" placeholder="e.g. AI Integrations Intern" required>
                  </div>
                  <div class="col-md-6 mb-3">
                    <label class="form-label text-sm text-light">Company Name</label>
                    <input type="text" class="form-control" name="company" placeholder="e.g. Cognifyz Labs" required>
                  </div>
                </div>

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label text-sm text-light">Job Location</label>
                    <input type="text" class="form-control" name="location" placeholder="e.g. Remote (India)" required>
                  </div>
                  <div class="col-md-3 mb-3">
                    <label class="form-label text-sm text-light">Job Type</label>
                    <select class="form-select" name="type">
                      <option value="Internship" selected>Internship</option>
                      <option value="Full-time">Full-time</option>
                      <option value="Part-time">Part-time</option>
                      <option value="Remote">Remote Only</option>
                    </select>
                  </div>
                  <div class="col-md-3 mb-3">
                    <label class="form-label text-sm text-light">Stipend/Salary</label>
                    <input type="text" class="form-control" name="salary" placeholder="e.g. ₹20,000 / month">
                  </div>
                </div>

                <div class="mb-3">
                  <label class="form-label text-sm text-light">Required Skills (Comma separated list)</label>
                  <input type="text" class="form-control" name="requirements" placeholder="e.g. Node.js, Express, MongoDB, Prompt Engineering" required>
                </div>

                <div class="mb-4">
                  <label class="form-label text-sm text-light">Job Role Description</label>
                  <textarea class="form-control" name="description" rows="4" placeholder="Outline day-to-day responsibilities, expectations, and benefits..." required></textarea>
                </div>

                <button type="submit" class="btn btn-premium rounded-pill px-5">
                  Publish Internship<i class="fa-solid fa-paper-plane ms-2"></i>
                </button>
              </form>
            </div>
          </div>
        <% } %>

      </main>
    </div>
  </div>
</div>

<!-- ==================================================== -->
<!-- APPLICATION SUBMISSION OFF-CANVAS / MODAL -->
<!-- ==================================================== -->
<div class="modal fade glass-modal" id="applyModal" tabindex="-1" aria-labelledby="applyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card">
      <div class="modal-header border-bottom border-secondary border-opacity-10">
        <h5 class="modal-title font-outfit text-white" id="applyModalLabel">Submit Application</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <h6 class="text-white" id="applyJobTitle">Job Title</h6>
          <span class="text-muted text-xs d-block mb-3" id="applyJobCompany">Company</span>
        </div>

        <form id="submissionUploadForm" enctype="multipart/form-data">
          <input type="hidden" name="jobId" id="applyJobId">
          
          <div class="mb-3">
            <label class="form-label text-xs text-light">Upload Resume (PDF or TXT, Max 5MB)</label>
            <input type="file" class="form-control" name="resume" id="applyResumeInput" accept=".pdf,.txt" required>
          </div>

          <!-- Dynamic application process loader status bar (Task 4/5) -->
          <div id="applyStatusWrapper" class="d-none mt-4">
            <div class="progress rounded-pill bg-dark-50 border border-secondary border-opacity-10 mb-2" style="height: 10px;">
              <div id="applyProgressBar" class="progress-bar progress-bar-striped progress-bar-animated rounded-pill bg-gradient-purple" role="progressbar" style="width: 0%"></div>
            </div>
            <div class="d-flex justify-content-between text-xs">
              <span id="applyProgressText" class="text-muted">Reading file metadata...</span>
              <span id="applyProgressPercent" class="fw-bold">0%</span>
            </div>
          </div>

          <div class="text-end mt-4">
            <button type="button" class="btn btn-dark-50 border border-secondary border-opacity-10 rounded-pill px-4 text-xs me-2" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" id="submitApplyBtn" class="btn btn-premium rounded-pill px-4 text-xs">Submit & AI Analyze</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- ==================================================== -->
<!-- AI ANALYSIS DETAILS MODAL (Task 7 representation) -->
<!-- ==================================================== -->
<div class="modal fade glass-modal" id="aiAnalysisModal" tabindex="-1" aria-labelledby="aiAnalysisModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content glass-card">
      <div class="modal-header border-bottom border-secondary border-opacity-10">
        <div class="d-flex align-items-center">
          <i class="fa-solid fa-sparkles text-gradient fs-4 me-2"></i>
          <h5 class="modal-title font-outfit text-white" id="aiAnalysisModalLabel">Gemini AI ATS Matrix Report</h5>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="row g-4 mb-4">
          <!-- Left: Circular metric indicator score -->
          <div class="col-md-4 text-center d-flex flex-column justify-content-center align-items-center border-end border-secondary border-opacity-10">
            <div class="ats-circular-meter mb-3">
              <div class="inner-circle">
                <span id="aiReportScore" class="font-outfit text-white fs-2 fw-extrabold">--</span>
                <span class="text-muted text-xs">ATS Rating</span>
              </div>
            </div>
            <span class="badge rounded-pill badge-hero-glow px-3 py-1 mt-1 text-uppercase text-xs" id="aiReportBadge">Pending</span>
          </div>

          <!-- Right: Core Skills Identified -->
          <div class="col-md-8">
            <h6 class="text-white font-outfit mb-3"><i class="fa-solid fa-tags text-primary me-2"></i>Core Skills Extracted</h6>
            <div class="d-flex flex-wrap gap-2" id="aiReportSkills">
              <!-- Dynamically mapped skills -->
              <span class="text-muted text-sm">Analyzing metadata...</span>
            </div>
          </div>
        </div>

        <hr class="border-secondary opacity-10 my-4">

        <!-- Tab contents for gap analysis and suggestions -->
        <div class="row g-4">
          <div class="col-md-6">
            <div class="card bg-dark-50 rounded-4 border-0 p-3 h-100">
              <h6 class="text-white font-outfit mb-2"><i class="fa-solid fa-triangle-exclamation text-gradient-amber me-2"></i>Skill Gap Analysis</h6>
              <p id="aiReportGap" class="text-muted text-xs mb-0" style="line-height: 1.6;">--</p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card bg-dark-50 rounded-4 border-0 p-3 h-100">
              <h6 class="text-white font-outfit mb-2"><i class="fa-solid fa-compass text-gradient-teal me-2"></i>Target Career Tracks</h6>
              <ul id="aiReportSuggestions" class="ps-3 mb-0 text-muted text-xs" style="line-height: 1.6;">
                <!-- Suggestions -->
              </ul>
            </div>
          </div>

          <div class="col-12 mt-4">
            <div class="card bg-dark-50 rounded-4 border-0 p-3">
              <h6 class="text-white font-outfit mb-2"><i class="fa-solid fa-list-check text-gradient-purple me-2"></i>Actionable Path Suggestions</h6>
              <ul id="aiReportRecommendations" class="ps-3 mb-0 text-muted text-xs" style="line-height: 1.6;">
                <!-- Recommendations -->
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
