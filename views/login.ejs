<%- include('partials/header') %>

<main class="container py-5 d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 160px);">
  <div class="glow-sphere sphere-3"></div>
  <div class="row justify-content-center w-100">
    <div class="col-md-8 col-lg-5">
      <div class="glass-card p-4 p-sm-5 shadow-lg position-relative z-index-2">
        <div class="text-center mb-4">
          <i class="fa-solid fa-lock-open text-gradient-purple fs-1 mb-3"></i>
          <h2 class="font-outfit text-white mb-1">Welcome Back</h2>
          <p class="text-muted text-sm">Access your personalized AI career portal</p>
        </div>

        <!-- Express validation display alerts -->
        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-danger bg-danger-10 border-danger border-opacity-25 rounded-4 text-sm text-white" role="alert">
            <ul class="mb-0 ps-3">
              <% errors.forEach(function(err) { %>
                <li><%= err %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <form action="/login" method="POST" id="authLoginForm" novalidate>
          <div class="mb-4">
            <label for="loginEmail" class="form-label text-sm text-light">Email Address</label>
            <div class="input-group-glass">
              <span class="input-icon"><i class="fa-regular fa-envelope text-muted"></i></span>
              <input 
                type="email" 
                class="form-control" 
                id="loginEmail" 
                name="email" 
                placeholder="name@domain.com" 
                value="<%= prevInput && prevInput.email ? prevInput.email : '' %>"
                required
              >
            </div>
            <div class="invalid-feedback-custom text-xs text-danger mt-1" id="loginEmailErr"></div>
          </div>

          <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <label for="loginPassword" class="form-label text-sm text-light mb-0">Password</label>
            </div>
            <div class="input-group-glass">
              <span class="input-icon"><i class="fa-solid fa-key text-muted"></i></span>
              <input 
                type="password" 
                class="form-control" 
                id="loginPassword" 
                name="password" 
                placeholder="Enter password" 
                required
              >
            </div>
            <div class="invalid-feedback-custom text-xs text-danger mt-1" id="loginPasswordErr"></div>
          </div>

          <button type="submit" class="btn btn-premium w-100 rounded-pill py-2 shadow mt-3">
            Sign In<i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
          </button>
        </form>

        <div class="text-center mt-4">
          <p class="text-muted text-sm mb-0">
            Don't have an account? 
            <a href="/register" class="text-gradient font-bold text-decoration-none ms-1 hover-underline">Register</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
